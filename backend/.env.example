# Anthropic API key (required) - https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Port the Express server listens on
PORT=3001

# Origin allowed to call this API (the Vite dev server)
FRONTEND_ORIGIN=http://localhost:5173

# Claude model used for the agent. Swap to claude-opus-4-8 for higher-quality
# reasoning at higher cost/latency.
CLAUDE_MODEL=claude-sonnet-5

# Google Maps API key (optional) - needs Geocoding API, Directions API,
# Maps JavaScript API, and Places API enabled + billing set up in Google
# Cloud Console. Without it, the agent falls back to inventing activities
# from its own knowledge instead of researching real candidates via Places,
# and itineraries have no coordinates/route/lodging data.
GOOGLE_MAPS_API_KEY=

# Dev-only cost lever, leave unset/false normally. When true, skips the
# walking-budget retry loop and accepts Claude's first propose_itinerary
# attempt as-is (Mobility Score is still computed honestly either way — this
# only skips asking Claude to regenerate the itinerary). Roughly halves the
# Claude cost of a full itinerary-generation test run. Do NOT leave this true
# for a real demo/interview run — it trades away the walking-budget guarantee.
SKIP_BUDGET_VALIDATION=false
